---
// src/components/BeatsFilter.astro

/**
 * Multi-filter component for beats
 * Uses dropdowns with tag-style selections for better UX
 */

// Episode filters
const episodeFilters = {
  all: 'All Episodes',
  episode_1: 'Episode 1',
  episode_2: 'Episode 2',
  episode_3: 'Episode 3',
  episode_4: 'Episode 4',
  episode_5: 'Episode 5',
  episode_6: 'Episode 6'
};

// Movement type filters
const movementTypeFilters = {
  all: 'All Movement Types',
  escalation: 'Escalation',
  deescalation: 'Deescalation',
  reversal: 'Reversal',
  turn: 'Turn',
  stasis: 'Stasis',
  internal_shift: 'Internal Shift'
};

// Information type filters
const informationTypeFilters = {
  all: 'All Information Types',
  none: 'No Information',
  setup: 'Setup',
  reveal: 'Reveal',
  plant: 'Plant',
  payoff: 'Payoff',
  withholding: 'Withholding',
  misdirect: 'Misdirect'
};

// Scope filters
const scopeFilters = {
  all: 'All Scopes',
  internal: 'Internal',
  interpersonal: 'Interpersonal',
  subplot: 'Subplot',
  primary_plot: 'Primary Plot',
  global: 'Global'
};

// Character filters (based on primary_character field)
const characterFilters = {
  all: 'All Characters',
  'john-lennon': 'John Lennon',
  'paul-mccartney': 'Paul McCartney',
  'george-harrison': 'George Harrison',
  'ringo-starr': 'Ringo Starr',
  'nigel-finch': 'Nigel Finch',
  'clive-barrow': 'Clive Barrow',
  'yoko-ono': 'Yoko Ono',
  'queen-elizabeth': 'Queen Elizabeth',
  'prince-phillip': 'Prince Philip',
  'lord-mountbatten': 'Lord Mountbatten',
  'sir-derek-finchley': 'Sir Derek Finchley',
  'brian-epstein': 'Brian Epstein',
  'arthur-jenkins': 'Arthur Jenkins'
};

// Engine filters
const engineFilters = {
  all: 'All Engines',
  character: 'Character',
  institution: 'Institution',
  cultural: 'Cultural'
};

// Irreversibility filters
const irreversibilityFilters = {
  all: 'All Irreversibility',
  none: 'None',
  personal: 'Personal',
  public: 'Public',
  historical: 'Historical'
};
---

<div 
  class="beats-filters"
  x-data="{
    activeFilters: {
      episode: [],
      movementType: [],
      informationType: [],
      scope: [],
      character: [],
      engine: [],
      irreversibility: []
    },
    dropdowns: {
      episode: false,
      movementType: false,
      informationType: false,
      scope: false,
      character: false,
      engine: false,
      irreversibility: false
    },
    
    toggleDropdown(category) {
      this.dropdowns[category] = !this.dropdowns[category];
      // Close other dropdowns
      Object.keys(this.dropdowns).forEach(key => {
        if (key !== category) {
          this.dropdowns[key] = false;
        }
      });
    },
    
    closeAllDropdowns() {
      Object.keys(this.dropdowns).forEach(key => {
        this.dropdowns[key] = false;
      });
    },
    
    addFilter(category, key, label) {
      if (!this.activeFilters[category].find(f => f.key === key)) {
        this.activeFilters[category].push({ key, label });
        this.filterItems();
      }
      this.dropdowns[category] = false;
    },
    
    removeFilter(category, key) {
      this.activeFilters[category] = this.activeFilters[category].filter(f => f.key !== key);
      this.filterItems();
    },
    
    clearAllFilters() {
      this.activeFilters = {
        episode: [],
        movementType: [],
        informationType: [],
        scope: [],
        character: [],
        engine: [],
        irreversibility: []
      };
      this.filterItems();
    },
    
    filterItems() {
      // Filter scene blocks
      const scenes = document.querySelectorAll('.scene-block');
      let visibleScenes = 0;
      let totalVisibleBeats = 0;
      
      scenes.forEach(scene => {
        const categories = JSON.parse(scene.getAttribute('data-category') || '[]');
        
        let matches = true;
        
        // Check each filter category
        if (this.activeFilters.episode.length > 0) {
          matches = matches && this.activeFilters.episode.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.movementType.length > 0) {
          matches = matches && this.activeFilters.movementType.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.informationType.length > 0) {
          matches = matches && this.activeFilters.informationType.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.scope.length > 0) {
          matches = matches && this.activeFilters.scope.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.character.length > 0) {
          matches = matches && this.activeFilters.character.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.engine.length > 0) {
          matches = matches && this.activeFilters.engine.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.irreversibility.length > 0) {
          matches = matches && this.activeFilters.irreversibility.some(f => categories.includes(f.key));
        }
        
        if (matches) {
          scene.style.display = 'block';
          scene.classList.remove('filter-hidden');
          visibleScenes++;
          
          // Count visible beats in this scene
          const beatsInScene = scene.querySelectorAll('.beat-card');
          beatsInScene.forEach(beat => {
            beat.style.display = 'block';
            beat.classList.remove('filter-hidden');
            totalVisibleBeats++;
          });
        } else {
          scene.style.display = 'none';
          scene.classList.add('filter-hidden');
          
          // Hide all beats in this scene
          const beatsInScene = scene.querySelectorAll('.beat-card');
          beatsInScene.forEach(beat => {
            beat.style.display = 'none';
            beat.classList.add('filter-hidden');
          });
        }
      });
      
      // Update result count
      const countElement = document.querySelector('.results-count');
      if (countElement) {
        countElement.textContent = `${totalVisibleBeats} beats in ${visibleScenes} scenes`;
      }
    }
  }"
  x-init="filterItems()"
  @click.away="closeAllDropdowns()"
>
  <div class="filter-header">
    <h2 class="filter-title">Filter Beats</h2>
    <div class="results-count"></div>

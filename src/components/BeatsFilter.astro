---
// src/components/BeatsFilter.astro

import BaseFilter from "./BaseFilter.astro";

/**
 * Beats-specific filter component
 * Filters story beats by movement_type, information_type, and scope fields
 */

const beatsFilters = {
  all: 'All Beats',
  escalation: 'Escalation',
  deescalation: 'Deescalation',
  reversal: 'Reversal',
  turn: 'Turn',
  stasis: 'Stasis',
  internal_shift: 'Internal Shift',
  setup: 'Setup',
  reveal: 'Reveal',
  plant: 'Plant',
  payoff: 'Payoff',
  withholding: 'Withholding',
  misdirect: 'Misdirect',
  none: 'No Information',
  internal: 'Internal',
  interpersonal: 'Interpersonal',
  subplot: 'Subplot',
  primary_plot: 'Primary Plot',
  global: 'Global'
};
---

<BaseFilter 
  title="Filter by Beat Attributes"
  filters={beatsFilters}
  resultLabel="beats"
/>

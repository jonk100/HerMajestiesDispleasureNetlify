---
export interface Props {
  title: string;
  alpineState: string;
  children?: any;
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { title, alpineState, children, headingLevel = 'h4' } = Astro.props;

const HeadingTag = headingLevel;
---

<div class="collapsible-section" x-data="{ expanded: false }">
  <button 
    class="section-header"
    :class="{ 'expanded': expanded }"
    @click={`expanded = !expanded; ${alpineState} = expanded`}
  >
    <HeadingTag>{title}</HeadingTag>
    <svg 
      class="expand-icon" 
      :class="{ 'rotated': expanded }"
      width="16" 
      height="16" 
      viewBox="0 0 16 16" 
      fill="currentColor"
    >
      <path d="M4.427 9.573L8 6l3.573 3.573a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708z"/>
    </svg>
  </button>
  
  <div 
    class="section-content"
    :class="{ 'expanded': expanded }"
    x-show="expanded"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 max-h-0"
    x-transition:enter-end="opacity-100 max-h-screen"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 max-h-screen"
    x-transition:leave-end="opacity-0 max-h-0"
  >
    {children}
  </div>
</div>

<style>
  .collapsible-section {
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 6px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .section-header {
    width: 100%;
    background: var(--color-surface, #ffffff);
    border: none;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: background-color 0.2s ease;
    text-align: left;
  }

  .section-header:hover {
    background: var(--color-background, #f9f9f9);
  }

  .section-header.expanded {
    background: var(--color-primary-bg, #e3f2fd);
    border-bottom: 1px solid var(--color-border, #e0e0e0);
  }

  .section-header h2,
  .section-header h3,
  .section-header h4 {
    margin: 0;
    color: var(--color-text-primary, #1a1a1a);
  }

  .section-header h2 {
    font-size: 1.5rem;
  }

  .section-header h3 {
    font-size: 1.25rem;
  }

  .section-header h4 {
    font-size: 1.1rem;
  }

  .expand-icon {
    transition: transform 0.2s ease;
    color: var(--color-text-secondary, #666666);
    flex-shrink: 0;
  }

  .expand-icon.rotated {
    transform: rotate(180deg);
  }

  .section-content {
    background: var(--color-background, #f9f9f9);
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: opacity 0.15s ease-in, max-height 0.15s ease-in;
  }

  .section-content.expanded {
    max-height: none;
    opacity: 1;
    transition: opacity 0.2s ease-out, max-height 0.2s ease-out;
  }
</style>

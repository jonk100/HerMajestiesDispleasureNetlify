---
/**
 * VoiceEnabled Component
 * 
 * Wrapper component that provides voice functionality to any content
 * Uses the centralized VoiceHandler utility to eliminate duplication
 */

import { voiceMap } from "../utils/voices/voiceMap.ts";

export interface Props {
  voiceType: 'character' | 'narrator';
  speaker?: string;
  elementType: 'dialogue' | 'action';
}

const { voiceType, speaker, elementType } = Astro.props;

const voice = speaker
  ? voiceMap.characters[speaker] ?? voiceMap.narrator
  : voiceMap.narrator;
---

<div class={`voice-enabled ${elementType}`} data-voice={voice?.id}>
  {voice && <button class="speak" aria-label={`Play ${elementType}`}>▶</button>}
  <slot />
</div>

{voice && (
<script is:inline>
(() => {
  // Import the VoiceHandler class
  import('./src/utils/voice/VoiceHandler.js').then(({ VoiceHandler }) => {
    // Initialize voice handling for this element type
    VoiceHandler.initializeVoiceElements('{elementType}');
  }).catch(error => {
    console.error('Failed to load VoiceHandler:', error);
  });
})();
</script>
)}

<style>
  .voice-enabled {
    position: relative;
  }

  .voice-enabled .speak {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--color-primary, #0066cc);
    color: white;
    border: none;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    font-size: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    z-index: 1;
  }

  .voice-enabled .speak:hover {
    background: var(--color-primary-hover, #0056b3);
    transform: scale(1.1);
  }

  .voice-enabled .speak:active {
    transform: scale(0.95);
  }

  /* Dialogue specific styling */
  .voice-enabled.dialogue .speak {
    top: -8px;
    right: -8px;
  }

  /* Action specific styling */
  .voice-enabled.action .speak {
    top: -4px;
    right: -4px;
    background: var(--color-accent, #764ba2);
  }

  .voice-enabled.action .speak:hover {
    background: var(--color-accent-hover, #5e3a8a);
  }
</style>

---
interface Props {
  content: string;
  referenceCollections: Record<string, any[]>;
}

const { content, referenceCollections } = Astro.props;

// Parse content into lines for editing
const lines = content.split('\n');
---

<div class="screenplay-editor">
  <div class="editor-toolbar">
    <div class="toolbar-section">
      <button type="button" class="toolbar-btn" onclick="convertLineType('scene')" title="Scene Heading (s-)">
        <span class="btn-icon">📍</span>
        Scene
      </button>
      <button type="button" class="toolbar-btn" onclick="convertLineType('action')" title="Action (a-)">
        <span class="btn-icon">🎬</span>
        Action
      </button>
      <button type="button" class="toolbar-btn" onclick="convertLineType('character')" title="Character (c-)">
        <span class="btn-icon">👤</span>
        Character
      </button>
      <button type="button" class="toolbar-btn" onclick="convertLineType('dialogue')" title="Dialogue (d-)">
        <span class="btn-icon">💬</span>
        Dialogue
      </button>
      <button type="button" class="toolbar-btn" onclick="convertLineType('parenthetical')" title="Parenthetical (p-)">
        <span class="btn-icon">📝</span>
        Parenthetical
      </button>
      <button type="button" class="toolbar-btn" onclick="convertLineType('transition')" title="Transition (t-)">
        <span class="btn-icon">➡️</span>
        Transition
      </button>
    </div>
    
    <div class="toolbar-section">
      <button type="button" class="toolbar-btn" onclick="formatSelection('bold')" title="Bold">
        <span class="btn-icon">**B**</span>
      </button>
      <button type="button" class="toolbar-btn" onclick="formatSelection('italic')" title="Italic">
        <span class="btn-icon">*I*</span>
      </button>
      <button type="button" class="toolbar-btn" onclick="insertCharacterReference()" title="Insert Character">
        <span class="btn-icon">👥</span>
        Characters
      </button>
    </div>
  </div>

  <div class="editor-container">
    <div class="line-numbers" id="line-numbers">
      {lines.map((_, index) => (
        <div class="line-number">{index + 1}</div>
      ))}
    </div>
    
    <textarea 
      id="screenplay-content"
      name="body"
      class="screenplay-textarea"
      placeholder="Enter screenplay content...&#10;&#10;Use prefixes:&#10;s- Scene heading&#10;a- Action&#10;c- Character&#10;d- Dialogue&#10;p- Parenthetical&#10;t- Transition&#10;&#10;Or use implicit formatting:&#10;INT./EXT. for scenes&#10;ALL CAPS for characters&#10;(parentheses) for parentheticals"
      spellcheck="false"
    >{content}</textarea>
  </div>

  <div class="editor-footer">
    <div class="formatting-help">
      <details>
        <summary>Formatting Help</summary>
        <div class="help-content">
          <h4>Prefixes:</h4>
          <ul>
            <li><code>s-</code> or <code>scene-</code> - Scene heading</li>
            <li><code>a-</code> or <code>action-</code> - Action description</li>
            <li><code>c-</code> or <code>character-</code> - Character name</li>
            <li><code>d-</code> or <code>dialogue-</code> - Dialogue</li>
            <li><code>p-</code> or <code>parenthetical-</code> - Parenthetical</li>
            <li><code>t-</code> or <code>transition-</code> - Transition</li>
            <li><code>ab-</code> or <code>act-break-</code> - Act break</li>
          </ul>
          
          <h4>Implicit Formatting:</h4>
          <ul>
            <li>Lines starting with <code>INT.</code>, <code>EXT.</code>, or <code>INT./EXT.</code> become scene headings</li>
            <li>ALL CAPS lines become character names</li>
            <li>Lines in parentheses become parentheticals</li>
            <li>Use <code>//Name</code> for inline character name formatting</li>
          </ul>
          
          <h4>Keyboard Shortcuts:</h4>
          <ul>
            <li><code>Ctrl+S</code> - Save</li>
            <li><code>Ctrl+B</code> - Bold</li>
            <li><code>Ctrl+I</code> - Italic</li>
            <li><code>Ctrl+1-6</code> - Convert line type</li>
          </ul>
        </div>
      </details>
    </div>
  </div>
</div>

<script define:vars={{ referenceCollections }}>
  let screenplayTextarea;
  let lineNumbers;

  document.addEventListener('DOMContentLoaded', () => {
    screenplayTextarea = document.getElementById('screenplay-content');
    lineNumbers = document.getElementById('line-numbers');
    
    if (screenplayTextarea && lineNumbers) {
      // Sync scrolling
      screenplayTextarea.addEventListener('scroll', syncScroll);
      
      // Update line numbers on content change
      screenplayTextarea.addEventListener('input', updateLineNumbers);
      screenplayTextarea.addEventListener('keydown', handleKeyDown);
      
      // Initial setup
      updateLineNumbers();
      syncLineHeight();
    }
  });

  function syncScroll() {
    if (lineNumbers && screenplayTextarea) {
      lineNumbers.scrollTop = screenplayTextarea.scrollTop;
    }
  }

  function updateLineNumbers() {
    const lines = screenplayTextarea.value.split('\n');
    const lineCount = lines.length;
    const lineNumbersHtml = Array.from({length: lineCount}, (_, i) => i + 1).join('<br>');
    lineNumbers.innerHTML = lineNumbersHtml;
  }

  function syncLineHeight() {
    if (!screenplayTextarea || !lineNumbers) return;
    
    // Copy textarea styles to line numbers
    const computedStyle = window.getComputedStyle(screenplayTextarea);
    const lineHeight = computedStyle.lineHeight;
    const paddingTop = computedStyle.paddingTop;
    const paddingBottom = computedStyle.paddingBottom;
    
    lineNumbers.style.lineHeight = lineHeight;
    lineNumbers.style.paddingTop = paddingTop;
    lineNumbers.style.paddingBottom = paddingBottom;
  }

  function handleKeyDown(event) {
    if (!screenplayTextarea) return;
    
    // Handle tab key for indentation
    if (event.key === 'Tab') {
      event.preventDefault();
      const start = screenplayTextarea.selectionStart;
      const end = screenplayTextarea.selectionEnd;
      const value = screenplayTextarea.value;
      
      screenplayTextarea.value = value.substring(0, start) + '  ' + value.substring(end);
      screenplayTextarea.selectionStart = screenplayTextarea.selectionEnd = start + 2;
    }
    
    // Handle keyboard shortcuts
    if (event.ctrlKey || event.metaKey) {
      switch (event.key) {
        case 'b':
          event.preventDefault();
          formatSelection('bold');
          break;
        case 'i':
          event.preventDefault();
          formatSelection('italic');
          break;
        case '1':
          event.preventDefault();
          convertLineType('scene');
          break;
        case '2':
          event.preventDefault();
          convertLineType('action');
          break;
        case '3':
          event.preventDefault();
          convertLineType('character');
          break;
        case '4':
          event.preventDefault();
          convertLineType('dialogue');
          break;
        case '5':
          event.preventDefault();
          convertLineType('parenthetical');
          break;
        case '6':
          event.preventDefault();
          convertLineType('transition');
          break;
      }
    }
  }

  function convertLineType(lineType) {
    if (!screenplayTextarea) return;
    
    const start = screenplayTextarea.selectionStart;
    const end = screenplayTextarea.selectionEnd;
    const value = screenplayTextarea.value;
    
    // Get current line
    const lines = value.split('\n');
    let currentLineIndex = 0;
    let charCount = 0;
    
    for (let i = 0; i < lines.length; i++) {
      if (charCount + lines[i].length + 1 > start) {
        currentLineIndex = i;
        break;
      }
      charCount += lines[i].length + 1;
    }
    
    let currentLine = lines[currentLineIndex];
    
    // Remove existing prefixes
    const prefixes = ['s-', 'scene-', 'a-', 'action-', 'c-', 'character-', 'd-', 'dialogue-', 'p-', 'parenthetical-', 't-', 'transition-', 'ab-', 'act-break-'];
    for (const prefix of prefixes) {
      if (currentLine.toLowerCase().startsWith(prefix)) {
        currentLine = currentLine.substring(prefix.length).trim();
        break;
      }
    }
    
    // Add new prefix
    const newPrefix = lineType + '-';
    lines[currentLineIndex] = newPrefix + currentLine;
    
    // Update textarea
    screenplayTextarea.value = lines.join('\n');
    
    // Restore cursor position
    const newStart = value.substring(0, start).lastIndexOf('\n') + 1 + newPrefix.length;
    screenplayTextarea.selectionStart = screenplayTextarea.selectionEnd = newStart;
    
    updateLineNumbers();
  }

  function formatSelection(format) {
    if (!screenplayTextarea) return;
    
    const start = screenplayTextarea.selectionStart;
    const end = screenplayTextarea.selectionEnd;
    const selectedText = screenplayTextarea.value.substring(start, end);
    
    if (!selectedText) return;
    
    let formattedText = '';
    switch (format) {
      case 'bold':
        formattedText = `**${selectedText}**`;
        break;
      case 'italic':
        formattedText = `*${selectedText}*`;
        break;
      default:
        formattedText = selectedText;
    }
    
    screenplayTextarea.value = screenplayTextarea.value.substring(0, start) + formattedText + screenplayTextarea.value.substring(end);
    
    // Restore selection
    screenplayTextarea.selectionStart = start;
    screenplayTextarea.selectionEnd = start + formattedText.length;
    screenplayTextarea.focus();
  }

  function insertCharacterReference(character) {
    if (!screenplayTextarea) return;
    
    const characters = JSON.parse('{JSON.stringify(referenceCollections.characters || [])}');
    if (!characters.length) {
      alert('No characters available');
      return;
    }
    
    const characterNames = characters.map(char => char.data.name || char.id);
    const selectedCharacter = prompt('Select character:\n' + characterNames.map((name, i) => `${i + 1}. ${name}`).join('\n'));
    
    if (selectedCharacter) {
      const start = screenplayTextarea.selectionStart;
      screenplayTextarea.value = screenplayTextarea.value.substring(0, start) + selectedCharacter + screenplayTextarea.value.substring(start);
      screenplayTextarea.selectionStart = screenplayTextarea.selectionEnd = start + selectedCharacter.length;
      screenplayTextarea.focus();
    }
  }

  // Make functions globally available
  window.convertLineType = convertLineType;
  window.formatSelection = formatSelection;
  window.insertCharacterReference = insertCharacterReference;
</script>

<style>
  .screenplay-editor {
    display: flex;
    flex-direction: column;
    height: 600px;
    border: 1px solid #ddd;
    border-radius: 6px;
    overflow: hidden;
  }

  .editor-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f8f9fa;
    border-bottom: 1px solid #ddd;
    padding: 0.5rem 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .toolbar-section {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .toolbar-btn {
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 0.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    transition: all 0.2s;
    color: #495057;
  }

  .toolbar-btn:hover {
    background: #e9ecef;
    border-color: #adb5bd;
  }

  .toolbar-btn:active {
    transform: translateY(1px);
  }

  .btn-icon {
    font-family: 'JetBrains Mono', monospace;
    font-weight: bold;
  }

  .editor-container {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .line-numbers {
    background: #f8f9fa;
    border-right: 1px solid #ddd;
    padding: 1rem 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #6c757d;
    text-align: right;
    user-select: none;
    overflow: hidden;
    min-width: 3rem;
  }

  .line-number {
    height: 1.5em;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .screenplay-textarea {
    flex: 1;
    border: none;
    outline: none;
    padding: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
    resize: none;
    background: white;
    color: #333;
  }

  .editor-footer {
    background: #f8f9fa;
    border-top: 1px solid #ddd;
    padding: 1rem;
  }

  .formatting-help details {
    cursor: pointer;
  }

  .formatting-help summary {
    font-weight: 600;
    color: #495057;
    padding: 0.5rem;
    border-radius: 4px;
    background: white;
    border: 1px solid #ddd;
  }

  .help-content {
    margin-top: 1rem;
    padding: 1rem;
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
  }

  .help-content h4 {
    margin: 1rem 0 0.5rem 0;
    color: #333;
  }

  .help-content h4:first-child {
    margin-top: 0;
  }

  .help-content ul {
    margin: 0.5rem 0;
    padding-left: 1.5rem;
  }

  .help-content li {
    margin-bottom: 0.25rem;
    font-size: 0.875rem;
  }

  .help-content code {
    background: #e9ecef;
    padding: 0.125rem 0.25rem;
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .screenplay-editor {
      height: 500px;
    }

    .editor-toolbar {
      padding: 0.5rem;
      gap: 0.5rem;
    }

    .toolbar-section {
      gap: 0.125rem;
    }

    .toolbar-btn {
      padding: 0.375rem;
      font-size: 0.6875rem;
    }

    .toolbar-btn span:not(.btn-icon) {
      display: none;
    }

    .screenplay-textarea {
      font-size: 0.8125rem;
      padding: 0.75rem;
    }

    .line-numbers {
      padding: 0.75rem 0.375rem;
      font-size: 0.8125rem;
      min-width: 2.5rem;
    }
  }
</style>

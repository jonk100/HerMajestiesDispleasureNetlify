      padding: 0.5rem;
      gap: 0.5rem;
    }

    .toolbar-section {
      gap: 0.125rem;
    }

    .toolbar-btn {
      padding: 0.375rem;
      font-size: 0.6875rem;
    }

    .toolbar-btn span:not(.btn-icon) {
      display: none;
    }

    .screenplay-content {
      font-size: 0.8125rem;
      padding: 0.75rem;
    }

    .line-numbers {

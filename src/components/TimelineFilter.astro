---
// src/components/TimelineFilter.astro

import { getCollection } from "astro:content";

interface Props {
  availableEpisodes?: number[];
  availableCharacters?: string[];
  availableThreads?: string[];
  initialFilters?: {
    episodes?: number[];
    characters?: string[];
    threads?: string[];
    pressureRange?: [number, number];
    viewMode?: 'overview' | 'episodes' | 'threads' | 'characters';
  };
}

// Get all data to populate filter options
const allBeats = await getCollection("beats");
const allEpisodes = await getCollection("episodes");
const allThreads = await getCollection("threads");

// Extract unique values from beats
const episodes = [...new Set(allBeats.map(beat => beat.data.episode))].sort((a: number, b: number) => a - b);
const characters = [...new Set(allBeats.map(beat => beat.data.primary_character))].sort();
const threadsFromBeats = [...new Set(allBeats.flatMap(beat => beat.data.thread_effects.map(effect => effect.thread)))].sort();

// Use props or derived values
const { availableEpisodes = episodes, availableCharacters = characters, availableThreads = threadsFromBeats, initialFilters } = Astro.props;

// Create filter option objects
const episodeFilters = {
  all: 'All Episodes',
  ...Object.fromEntries(availableEpisodes.map(ep => [`ep-${ep}`, `Episode ${ep}`]))
};

const characterFilters = {
  all: 'All Characters',
  ...Object.fromEntries(availableCharacters.map(char => [
    char.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase(),
    char.replace(/^(characters\/|royalty\/|band\/|supporting\/)/, '')
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (l: string) => l.toUpperCase())
  ]))
};

const threadFilters = {
  all: 'All Threads',
  ...Object.fromEntries(availableThreads.map(thread => [
    thread, // raw slug, no transformation
    thread.replace(/-/g, ' ').replace(/_/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())
  ]))
};

const viewModeFilters = {
  overview: 'Series Overview',
  episodes: 'By Episodes',
  threads: 'By Threads',
  characters: 'By Characters'
};

const pressureRangeFilters = {
  all: 'All Pressure',
  low: 'Low (1-3)',
  medium: 'Medium (4-6)',
  high: 'High (7-10)'
};
---

<div 
  class="timeline-filter-container"
  x-data=`{
    viewMode: '${initialFilters?.viewMode || 'overview'}',
    activeFilter: 'all',
    filterType: 'episodes',
    filters: {
      episodes: ${JSON.stringify(episodeFilters)},
      characters: ${JSON.stringify(characterFilters)},
      threads: ${JSON.stringify(threadFilters)},
      viewMode: ${JSON.stringify(viewModeFilters)},
      pressureRange: ${JSON.stringify(pressureRangeFilters)}
    },
    selectedEpisodes: [],
    selectedCharacters: [],
    selectedThreads: [],
    pressureRange: [1, 10],
    
    /**
     * Set the view mode for the timeline
     */
    setViewMode(mode) {
      this.viewMode = mode;
      this.activeFilter = 'all';
      this.applyFilters();
    },
    
    /**
     * Set the filter type
     */
    setFilterType(type) {
      this.filterType = type;
      this.activeFilter = 'all';
      this.applyFilters();
    },
    
    /**
     * Set active filter within current type
     */
    setFilter(filter) {
      this.activeFilter = filter;
      this.applyFilters();
    },
    
    /**
     * Apply filters based on current selections
     */
    applyFilters() {
      // Dispatch custom event with filter data
      const filterData = {
        viewMode: this.viewMode,
        episodes: this.getSelectedEpisodes(),
        characters: this.getSelectedCharacters(),
        threads: this.getSelectedThreads(),
        pressureRange: this.getPressureRange()
      };
      
      // Dispatch event for parent component to handle
      window.dispatchEvent(new CustomEvent('timelineFilterChange', {
        detail: filterData
      }));
      
      // Update UI
      this.updateTimelineDisplay();
    },
    
    /**
     * Get selected episodes based on active filter
     */
    getSelectedEpisodes() {
      if (this.activeFilter === 'all' || this.filterType !== 'episodes') {
        return [];
      }
      return [parseInt(this.activeFilter.replace('ep-', ''))];
    },
    
    /**
     * Get selected characters based on active filter
     */
    getSelectedCharacters() {
      if (this.activeFilter === 'all' || this.filterType !== 'characters') {
        return [];
      }
      return [this.activeFilter];
    },
    
    /**
     * Get selected threads based on active filter
     */
    getSelectedThreads() {
      if (this.activeFilter === 'all' || this.filterType !== 'threads') {
        return [];
      }
      return [this.activeFilter];
    },
    
    /**
     * Get pressure range based on active filter
     */
    getPressureRange() {
      if (this.activeFilter === 'all' || this.filterType !== 'pressureRange') {
        return [1, 10];
      }
      
      switch (this.activeFilter) {
        case 'low': return [1, 3];
        case 'medium': return [4, 6];
        case 'high': return [7, 10];
        default: return [1, 10];
      }
    },
    
    /**
     * Update timeline display based on filters
     */
    updateTimelineDisplay() {
      // This will be handled by the parent component listening to the custom event
      console.log('Timeline filters updated:', {
        viewMode: this.viewMode,
        filterType: this.filterType,
        activeFilter: this.activeFilter
      });
    },
    
    /**
     * Reset all filters
     */
    resetFilters() {
      this.viewMode = 'overview';
      this.filterType = 'episodes';
      this.activeFilter = 'all';
      this.selectedEpisodes = [];
      this.selectedCharacters = [];
      this.selectedThreads = [];
      this.pressureRange = [1, 10];
      this.applyFilters();
    }
  }`
  x-init="applyFilters()"
>
  <!-- Compact Filter Bar -->
  <div class="compact-filter-bar">
    <!-- View Mode Dropdown -->
    <div class="filter-dropdown">
      <label for="viewMode" class="filter-label">View:</label>
      <select 
        id="viewMode"
        x-model="viewMode"
        @change="setViewMode($event.target.value)"
        class="filter-select"
      >
        <template x-for="(label, key) in filters.viewMode" :key="key">
          <option :value="key" :selected="viewMode === key" x-text="label"></option>
        </template>
      </select>
    </div>

    <!-- Filter Type Dropdown -->
    <div class="filter-dropdown">
      <label for="filterType" class="filter-label">Filter:</label>
      <select 
        id="filterType"
        x-model="filterType"
        @change="setFilterType($event.target.value)"
        class="filter-select"
      >
        <option value="episodes" :selected="filterType === 'episodes'">Episodes</option>
        <option value="characters" :selected="filterType === 'characters'">Characters</option>
        <option value="threads" :selected="filterType === 'threads'">Threads</option>
        <option value="pressureRange" :selected="filterType === 'pressureRange'">Pressure</option>
      </select>
    </div>

    <!-- Filter Options Dropdown -->
    <div class="filter-dropdown">
      <label for="filterOption" class="filter-label">
        <span x-text="filterType === 'episodes' ? 'Episode:' : 
                       filterType === 'characters' ? 'Character:' :
                       filterType === 'threads' ? 'Thread:' : 'Range:'"></span>
      </label>
      <select 
        id="filterOption"
        x-model="activeFilter"
        @change="setFilter($event.target.value)"
        class="filter-select"
      >
        <template x-for="(label, key) in filters[filterType]" :key="key">
          <option :value="key" :selected="activeFilter === key" x-text="label"></option>
        </template>
      </select>
    </div>

    <!-- Reset Button -->
    <button 
      @click="resetFilters()"
      class="reset-btn"
      title="Reset all filters"
    >
      ↺ Reset
    </button>
  </div>

  <!-- Active Filters Display -->
  <div class="active-filters" x-show="activeFilter !== 'all' || viewMode !== 'overview'">
    <div class="active-filter-tags">
      <template x-if="viewMode !== 'overview'">
        <span class="filter-tag" x-text="filters.viewMode[viewMode]"></span>
      </template>
      <template x-if="activeFilter !== 'all'">
        <span class="filter-tag" x-text="filters[filterType][activeFilter]"></span>
      </template>
    </div>
  </div>

  <!-- Multi-select for advanced filtering (future enhancement) -->
  <div class="filter-section advanced-section" x-show="viewMode !== 'overview'">
    <details>
      <summary class="advanced-toggle">Advanced Options</summary>
      <div class="advanced-filters">
        <div class="multi-select-info">
          <p x-show="viewMode === 'threads'">
            <strong>Stack Multiple Threads:</strong> Select multiple threads to compare their pressure progression side by side.
          </p>
          <p x-show="viewMode === 'episodes'">
            <strong>Compare Episodes:</strong> Select multiple episodes to analyze pressure patterns across them.
          </p>
          <p x-show="viewMode === 'characters'">
            <strong>Character Arcs:</strong> Select multiple characters to see their individual pressure journeys.
          </p>
        </div>
        
        <!-- Multi-select interface would go here -->
        <div class="multi-select-placeholder">
          <em>Multi-select functionality coming soon...</em>
        </div>
      </div>
    </details>
  </div>
</div>

<style>
  .timeline-filter-container {
    background: var(--color-surface, #f8f9fa);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .compact-filter-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-dropdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .filter-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text, #6b7280);
    white-space: nowrap;
  }

  .filter-select {
    background: white;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 6px;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: var(--color-text, #1f2937);
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 120px;
  }

  .filter-select:hover {
    border-color: var(--color-accent, #6366f1);
  }

  .filter-select:focus {
    outline: none;
    border-color: var(--color-accent, #6366f1);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .reset-btn {
    background: var(--color-accent, #6366f1);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .reset-btn:hover {
    background: var(--color-accent-hover, #4f46e5);
    transform: translateY(-1px);
  }

  .active-filters {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
  }

  .active-filter-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-tag {
    background: var(--color-accent, #6366f1);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .timeline-filter-container {
      padding: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .compact-filter-bar {
      gap: 0.5rem;
    }

    .filter-dropdown {
      flex: 1;
      min-width: 0;
    }

    .filter-select {
      min-width: auto;
      width: 100%;
    }

    .reset-btn {
      flex-shrink: 0;
    }
  }

  @media (max-width: 480px) {
    .compact-filter-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-dropdown {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .filter-select {
      width: 100%;
    }

    .reset-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

---
// src/components/ThreadsFilter.astro

/**
 * Multi-filter component for threads
 * Uses dropdowns with tag-style selections for better UX
 */

// Episode filters
const episodeFilters = {
  all: 'All Episodes',
  episode_1: 'Episode 1',
  episode_2: 'Episode 2',
  episode_3: 'Episode 3',
  episode_4: 'Episode 4',
  episode_5: 'Episode 5',
  episode_6: 'Episode 6'
};

// Character filters
const characterFilters = {
  all: 'All Characters',
  'john-lennon': 'John Lennon',
  'paul-mccartney': 'Paul McCartney',
  'george-harrison': 'George Harrison',
  'ringo-starr': 'Ringo Starr',
  'nigel-finch': 'Nigel Finch',
  'clive-barrow': 'Clive Barrow',
  'yoko-ono': 'Yoko Ono',
  'queen-elizabeth': 'Queen Elizabeth',
  'prince-phillip': 'Prince Philip',
  'lord-mountbatten': 'Lord Mountbatten',
  'sir-derek-finchley': 'Sir Derek Finchley',
  'brian-epstein': 'Brian Epstein',
  'arthur-jenkins': 'Arthur Jenkins'
};

// Thread type filters
const typeFilters = {
  all: 'All Types',
  character_arc: 'Character Arc',
  relationship: 'Relationship',
  operational: 'Operational',
  thematic: 'Thematic',
  motif: 'Motif',
  plot: 'Plot'
};

// Status filters
const statusFilters = {
  all: 'All Statuses',
  open: 'Open',
  closed: 'Closed',
  dormant: 'Dormant',
  abandoned: 'Abandoned'
};
---

<div 
  class="threads-filters"
  x-data="{
    activeFilters: {
      episode: [],
      character: [], 
      type: [],
      status: []
    },
    dropdowns: {
      episode: false,
      character: false,
      type: false,
      status: false
    },
    
    toggleDropdown(category) {
      this.dropdowns[category] = !this.dropdowns[category];
      // Close other dropdowns
      Object.keys(this.dropdowns).forEach(key => {
        if (key !== category) {
          this.dropdowns[key] = false;
        }
      });
    },
    
    closeAllDropdowns() {
      Object.keys(this.dropdowns).forEach(key => {
        this.dropdowns[key] = false;
      });
    },
    
    addFilter(category, key, label) {
      if (!this.activeFilters[category].find(f => f.key === key)) {
        this.activeFilters[category].push({ key, label });
        this.filterItems();
      }
      this.dropdowns[category] = false;
    },
    
    removeFilter(category, key) {
      this.activeFilters[category] = this.activeFilters[category].filter(f => f.key !== key);
      this.filterItems();
    },
    
    clearAllFilters() {
      this.activeFilters = {
        episode: [],
        character: [], 
        type: [],
        status: []
      };
      this.filterItems();
    },
    
    filterItems() {
      const items = document.querySelectorAll('.thread-card');
      let visibleCount = 0;
      
      items.forEach(item => {
        const categories = JSON.parse(item.getAttribute('data-category') || '[]');
        
        let matches = true;
        
        // Check each filter category
        if (this.activeFilters.episode.length > 0) {
          matches = matches && this.activeFilters.episode.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.character.length > 0) {
          matches = matches && this.activeFilters.character.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.type.length > 0) {
          matches = matches && this.activeFilters.type.some(f => categories.includes(f.key));
        }
        
        if (this.activeFilters.status.length > 0) {
          matches = matches && this.activeFilters.status.some(f => categories.includes(f.key));
        }
        
        if (matches) {
          item.style.display = 'block';
          item.classList.remove('filter-hidden');
          visibleCount++;
        } else {
          item.style.display = 'none';
          item.classList.add('filter-hidden');
        }
      });
      
      // Update result count
      const countElement = document.querySelector('.results-count');
      if (countElement) {
        countElement.textContent = visibleCount + ' threads';
      }
    }
  }"
  x-init="filterItems()"
  @click.away="closeAllDropdowns()"
>
  <div class="filter-header">
    <h2 class="filter-title">Filter Threads</h2>
    <div class="results-count"></div>
    <button class="clear-all-btn" @click="clearAllFilters()" x-show="activeFilters.episode.length > 0 || activeFilters.character.length > 0 || activeFilters.type.length > 0 || activeFilters.status.length > 0">Clear All</button>
  </div>
  
  <div class="filter-sections">
    <!-- Episode Filter -->
    <div class="filter-section">
      <div class="filter-dropdown" @click="toggleDropdown('episode')">
        <span class="filter-label">Episode</span>
        <div class="filter-selected">
          <template x-if="activeFilters.episode.length === 0">
            <span class="placeholder">Select episodes...</span>
          </template>
          <template x-for="filter in activeFilters.episode" :key="filter.key">
            <span class="filter-tag" @click.stop="removeFilter('episode', filter.key)">
              <span x-text="filter.label"></span>
              <span class="remove">×</span>
            </span>
          </template>
        </div>
        <span class="dropdown-arrow" :class="{ 'open': dropdowns.episode }">▼</span>
      </div>
      
      <div class="dropdown-menu" x-show="dropdowns.episode" x-transition>
        <div 
          class="dropdown-item"
          @click.stop="addFilter('episode', 'all', 'All Episodes')"
          x-show="!activeFilters.episode.find(f => f.key === 'all')"
        >
          <span>All Episodes</span>
        </div>
        <div 
          class="dropdown-item"
          @click.stop="addFilter('episode', 'episode_1', 'Episode 1')"
          x-show="!activeFilters.episode.find(f => f.key === 'episode_1')"
        >

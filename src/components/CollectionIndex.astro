---
// src/components/CollectionIndex.astro

/**
 * Collection Index Component
 * 
 * Generic component for rendering collection index pages
 * Eliminates duplication across beats, characters, dialogue, and episodes pages
 */

import Layout from "@/layout/Layout.astro";

export interface CollectionItem {
  slug: string;
  title: string;
  href: string;
  meta?: Array<{
    type: string;
    value: string | number;
    className?: string;
  }>;
  description?: string;
  details?: Array<{
    label: string;
    value: string | number;
  }>;
}

export interface StatsLink {
  href: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  collection: CollectionItem[];
  filterComponent?: any;
  statsLink?: StatsLink;
  containerClass?: string;
}

const { 
  title, 
  description, 
  collection, 
  filterComponent, 
  statsLink,
  containerClass = "collection-container"
} = Astro.props;

// Helper function to create CSS class from label
function createLabelClass(label: string): string {
  return label.toLowerCase().replace(/\s+/g, '-');
}
---

<Layout title={title}>
  <div class={containerClass}>
    <div class="collection-header">
      <div>
        <h1>{title}</h1>
        <p>{description}</p>
      </div>
      {statsLink && (
        <a href={statsLink.href} class="stats-link">{statsLink.text}</a>
      )}
    </div>
    
    {filterComponent}
    
    <div class="items-grid">
      {collection.map((item) => (
        <div class="item-card">
          <h3>
            <a href={item.href}>{item.title}</a>
          </h3>
          
          {item.meta && item.meta.length > 0 && (
            <div class="meta">
              {item.meta.map((metaItem) => (
                <span class={metaItem.className || metaItem.type}>
                  {metaItem.value}
                </span>
              ))}
            </div>
          )}
          
          {item.description && (
            <p class="description">{item.description}</p>
          )}
          
          {item.details && item.details.length > 0 && (
            <div class="details">
              {item.details.map((detail) => (
                <p class={createLabelClass(detail.label)}>
                  <strong>{detail.label}:</strong> {detail.value}
                </p>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
    
    <div class="back-link">
      <a href="/">← Back to Collections</a>
    </div>
  </div>
</Layout>

<style>
  /* Basic collection styles */
  .collection-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .collection-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  
  .items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  
  .item-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1.5rem;
    background: white;
  }
  
  .item-card h3 {
    margin: 0 0 0.5rem 0;
  }
  
  .item-card h3 a {
    color: #1f2937;
    text-decoration: none;
  }
  
  .item-card h3 a:hover {
    color: #3b82f6;
  }
  
  .meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  
  .meta span {
    padding: 0.25rem 0.5rem;
    background: #f3f4f6;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }
  
  .description {
    color: #6b7280;
    margin-bottom: 1rem;
  }
  
  .details p {
    margin: 0.25rem 0;
    font-size: 0.875rem;
  }
  
  .back-link {
    margin-top: 2rem;
    text-align: center;
  }
  
  .back-link a {
    color: #6b7280;
    text-decoration: none;
  }
  
  .back-link a:hover {
    color: #1f2937;
  }
</style>

---
import { getCollection } from "astro:content";
import Layout from "@/layout/Layout.astro";
import BeatsFilter from "@/components/BeatsFilter.astro";

/**
 * Fetch and sort beats in story order.
 */
const beats = (await getCollection("beats")).sort((a, b) => {
  const A = a.data;
  const B = b.data;

  if (A.episode !== B.episode) return A.episode - B.episode;
  if (A.act !== B.act) return A.act - B.act;
  if (A.sequence !== B.sequence) return A.sequence - B.scene_number;
  if (A.scene_number !== B.scene_number) return A.scene_number - B.scene_number;
  return A.beat_index - B.beat_index;
});

/**
 * Get filter categories for a beat
 */
const getFilterCategories = (beat: any) => {
  const categories = [];
  
  // Add episode
  categories.push(`episode_${beat.data.episode}`);
  
  // Add movement type
  if (beat.data.movement_type) {
    categories.push(beat.data.movement_type);
  }
  
  // Add information type
  if (beat.data.information_type) {
    categories.push(beat.data.information_type);
  }
  
  // Add scope
  if (beat.data.scope) {
    categories.push(beat.data.scope);
  }
  
  // Add character (normalize primary_character)
  if (beat.data.primary_character) {
    const character = beat.data.primary_character.toLowerCase().replace(/\s+/g, '_');
    categories.push(character);
  }
  
  // Add engine
  if (beat.data.engine) {
    categories.push(beat.data.engine);
  }
  
  // Add irreversibility
  if (beat.data.irreversibility) {
    categories.push(beat.data.irreversibility);
  }
  
  return categories;
};

/**
 * Get filter categories for a scene (combines all beats in the scene)
 */
const getSceneFilterCategories = (scene: any) => {
  const allCategories = new Set();
  
  scene.beats.forEach((beat: any) => {
    const categories = getFilterCategories(beat);
    categories.forEach(cat => allCategories.add(cat));
  });
  
  return Array.from(allCategories);
};

/**
 * Group beats by scene.
 */
const scenes = beats.reduce((acc: Record<string, any>, beat) => {
  const key = `ep${beat.data.episode}-act${beat.data.act}-scene${beat.data.scene_number}`;

  if (!acc[key]) {
    acc[key] = {
      episode: beat.data.episode,
      act: beat.data.act,
      sequence: beat.data.sequence,
      scene_number: beat.data.scene_number,
      location: (beat.data as any).location || 'Unknown Location',
      summary: (beat.data as any).scene_summary || 'Scene Summary',
      beats: []
    };
  }

  acc[key].beats.push(beat);
  return acc;
}, {} as Record<string, any>);
---

<Layout title="Story Beats">
  <div class="container">
    <h1>Story Beats</h1>
    <p class="subtitle">Structural dashboard</p>

    <BeatsFilter />

    <div class="scenes-wrapper">

      {Object.values(scenes).map((scene) => (
        <details 
          class="scene-block"
          data-category={JSON.stringify(getSceneFilterCategories(scene))}
        >
          <summary class="scene-summary">

            <div class="scene-meta">
              <span>
                Ep {scene.episode} · 
                Act {scene.act} · 
                Scene {scene.scene_number}
              </span>
              <span class="location">{scene.location}</span>
            </div>

            <h2>{scene.summary}</h2>

          </summary>

          <div class="scene-beats">
            {scene.beats.map((beat: any) => (
              <div
                class="beat-card"
                data-category={JSON.stringify(getFilterCategories(beat))}
              >

                <div class="beat-position">
                  Beat {beat.data.beat_index}
                </div>

                <h3>
                  <a href={`/beats/${beat.slug}`}>
                    {beat.data.title}
                  </a>
                </h3>

                <div class="beat-meta">
                  <span class="type">
                    {(beat.data.movement_type ?? 'n/a')}/{(beat.data.information_type ?? 'n/a')}/{(beat.data.scope ?? 'n/a')}
                  </span>
                  <span class="character">{beat.data.primary_character}</span>
                </div>

                {beat.data.shift && (
                  <p class="shift">
                    <strong>Shift:</strong> {beat.data.shift}
                  </p>
                )}

                {(beat.data.stakes || beat.data.power_shift) && (
                  <div class="mini-meta">
                    {beat.data.stakes && (
                      <span><strong>Stakes:</strong> {beat.data.stakes}</span>
                    )}
                    {beat.data.power_shift && (
                      <span><strong>Power:</strong> {beat.data.power_shift}</span>
                    )}
                  </div>
                )}

                <!-- Pressure Bar -->
                <div class="pressure">
                  <div 
                    class="pressure-fill"
                    style={() => {
                      const raw = (beat.data as any).pressure_level;
                      if (typeof raw === 'number') {
                        const clamped = Math.min(Math.max(raw, 1), 10);
                        return `width: ${clamped * 10}%`;
                      }
                      return 'width: 50%';
                    }}
                  ></div>
                </div>

              </div>
            ))}
          </div>
        </details>
      ))}

    </div>

    <div class="back-link">
      <a href="/">← Back to Collections</a>
    </div>
  </div>
</Layout>

<style>
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

.subtitle {
  color: #666;
  margin-bottom: 2rem;
}

.scenes-wrapper {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.scene-block {
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  background: #fff;
}

.scene-summary {
  cursor: pointer;
  padding: .5rem;
  border-bottom: 1px solid #eee;
  list-style: none;
}

.scene-summary::-webkit-details-marker {
  display: none;
}

.scene-meta {
  font-size: 0.8rem;
  color: #888;
  margin-bottom: 0.5rem;
  display: flex;
  justify-content: space-between;
}

.location {
  font-style: italic;
}

.scene-summary h2 {
  margin: 0;
  font-size: 1.1rem;
}

.scene-beats {
  padding: 1.5rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.25rem;
}

.beat-card {
  border: 1px solid #f0f0f0;
  border-radius: 8px;
  padding: 1.25rem;
  background: #fafafa;
  transition: background 0.2s ease;
}

.beat-card:hover {
  background: #f4f4f4;
}

.beat-position {
  font-size: 0.75rem;
  color: #999;
  margin-bottom: 0.5rem;
}

.beat-card h3 {
  margin: 0 0 0.5rem 0;
}

.beat-card a {
  text-decoration: none;
  color: #222;
}

.beat-card a:hover {
  color: #0066cc;
}

.beat-meta {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}

.type {
  background: #fff3e0;
  color: #f57c00;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.7rem;
  text-transform: capitalize;
}

.character {
  background: #f0f0f0;
  color: #444;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.7rem;
}

.shift {
  font-size: 0.9rem;
  margin-bottom: 0.75rem;
}

.mini-meta {
  font-size: 0.75rem;
  color: #555;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 0.75rem;
}

/* Pressure bar */

.pressure {
  height: 6px;
  background: #e5e5e5;
  border-radius: 4px;
  overflow: hidden;
}

.pressure-fill {
  height: 100%;
  background: linear-gradient(
    to right,
    #cfd8dc,
    #ff9800,
    #d32f2f
  );
  transition: width 0.3s ease;
}

.back-link {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid #eee;
}

.back-link a {
  text-decoration: none;
  color: #666;
}

.back-link a:hover {
  color: #0066cc;
}
</style>

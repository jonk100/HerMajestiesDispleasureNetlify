---
import { getCollection } from "astro:content";
import Layout from "@/layout/collections/BeatsLayout.astro";

export async function getStaticPaths() {
  const beats = await getCollection("beats");
  return beats.map((beat) => ({
    params: { slug: beat.slug },
    props: { beat },
  }));
}

const { beat } = Astro.props;
const { Content } = await beat.render();
---

<Layout title={`${beat.data.title} - Beats`}>
  <div class="container">
    <div class="header">
      <h1>{beat.data.title}</h1>
      <div class="meta">
        <span class="act">Act {beat.data.act}</span>
        <span class="type">{beat.data.beat_type}</span>
        <span class="scene">
          Ep {beat.data.episode} · Seq {beat.data.sequence} · Scene {beat.data.scene_number}
        </span>
      </div>
    </div>

    <!-- Structural Movement -->
    <div class="section">
      <h2>Structural Movement</h2>

      <div class="movement">
        <p><strong>Before:</strong> {beat.data.status_quo_before}</p>
        <p class="shift">
          <strong>Shift:</strong> {beat.data.shift}
        </p>
        <p><strong>After:</strong> {beat.data.status_quo_after}</p>
      </div>
    </div>

    <!-- Engine -->
    <div class="section">
      <h2>Story Engine</h2>

      <p><strong>Structural Role:</strong> {beat.data.structural_role}</p>

      {beat.data.triggered_by && (
        <p><strong>Triggered By:</strong> {beat.data.triggered_by}</p>
      )}

      {beat.data.leads_to && (
        <p><strong>Leads To:</strong> {beat.data.leads_to}</p>
      )}
    </div>

    <!-- Conflict -->
    <div class="section">
      <h2>Conflict & Power</h2>

      <p><strong>Primary Character:</strong> {beat.data.primary_character}</p>
      <p><strong>Opposition:</strong> {beat.data.opposition}</p>
      <p><strong>Stakes:</strong> {beat.data.stakes}</p>
      <p><strong>Power Shift:</strong> {beat.data.power_shift}</p>
      <p><strong>Axis:</strong> {beat.data.public_private_axis}</p>
    </div>

    {(beat.data.plant || beat.data.payoff) && (
      <div class="section subtle">
        <h2>Setup / Payoff</h2>
        {beat.data.plant && (
          <p><strong>Plant:</strong> {beat.data.plant}</p>
        )}
        {beat.data.payoff && (
          <p><strong>Payoff:</strong> {beat.data.payoff}</p>
        )}
      </div>
    )}

    <!-- Theme -->
    <div class="section">
      <h2>Theme Expression</h2>
      <p>{beat.data.theme}</p>
    </div>

    <!-- Content Notes -->
    <div class="content">
      <Content />
    </div>

    <div class="back-link">
      <a href="/beats">← Back to Beats</a>
    </div>
  </div>
</Layout>
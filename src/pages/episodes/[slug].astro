---
import { getCollection, getEntry } from "astro:content";
import Layout from "@/layout/Layout.astro";
import "@/styles/screenplay.css";
import { calcEpisodeRuntime } from "@/utils/screenplay/calcEpisodeRuntime.ts";

import Screenplay from "@/components/screenplay/Screenplay.astro";
import Scene from "@/components/screenplay/Scene.astro";
import Action from "@/components/screenplay/Action.astro";
import Character from "@/components/screenplay/Character.astro";
import Dialogue from "@/components/screenplay/Dialogue.astro";
import Parenthetical from "@/components/screenplay/Parenthetical.astro";
import Transition from "@/components/screenplay/Transition.astro";
import ActBreak from "@/components/screenplay/ActBreak.astro";
import PageBreaker from "@/components/screenplay/PageBreaker.astro";
import PrintToPdf from "@/components/PrintToPdf.astro";
import EpisodeNav from "@/components/EpisodeNav.astro";
import VoiceConfigurator from "@/components/VoiceConfigurator.astro";


/**
 * Static paths for all episodes
 */
export async function getStaticPaths() {
  const episodes = await getCollection("episodes");

  return episodes.map((ep) => ({
    params: { slug: ep.slug },
    props: { slug: ep.slug },
  }));
}

const { slug } = Astro.props;

/**
 * Load episode entry
 */
const episode = await getEntry("episodes", slug);
if (!episode) throw new Error(`Episode not found: ${slug}`);

/**
 * Resolve ordered scenes exactly as declared in episode frontmatter
 */
const scenes = await Promise.all(
  episode.data.scenes.map((sceneRef) => getEntry(sceneRef))
);

const resolvedScenes = scenes.filter(
  (s): s is NonNullable<typeof s> => s !== null && s !== undefined
);

/**
 * Collect unique characters across episode
 */
const characterRefs = new Set<string>();
for (const scene of resolvedScenes) {
  for (const charRef of scene.data.characters) {
    characterRefs.add(JSON.stringify(charRef));
  }
}
const characters = await Promise.all(
  [...characterRefs].map((ref) => getEntry(JSON.parse(ref)))
);
const sortedCharacters = characters
  .filter((c): c is NonNullable<typeof c> => Boolean(c))
  .sort((a, b) => (a as any).data.name.localeCompare((b as any).data.name));

/**
 * Collect unique locations across episode
 */
const locationRefs = new Set<string>();
for (const scene of resolvedScenes) {
  const locs = Array.isArray(scene.data.location)
    ? scene.data.location 
    : [scene.data.location];
  for (const locRef of locs) {
    locationRefs.add(JSON.stringify(locRef));
  }
}
const locations = await Promise.all(
  [...locationRefs].map((ref) => getEntry(JSON.parse(ref)))
);
const sortedLocations = locations
  .filter((l): l is NonNullable<typeof l> => Boolean(l))
  .sort((a, b) => (a as any).data.name.localeCompare((b as any).data.name));

/**
 * Render scene MDX
 */
const renderedScenes = await Promise.all(
  resolvedScenes.map(async (scene) => ({
    scene,
    Content: (await scene.render()).Content,
  }))
);

// Calculate runtime dynamically
const calculatedRuntime = calcEpisodeRuntime(resolvedScenes);

/**
 * Load beats for this episode
 */
const allBeats = await getCollection("beats");
const episodeBeats = allBeats
  .filter(beat => beat.data.episode === episode.data.episode_number)
  .sort((a, b) => {
    // Sort by act, then sequence, then beat_index
    if (a.data.act !== b.data.act) return a.data.act - b.data.act;
    if (a.data.sequence !== b.data.sequence) return a.data.sequence - b.data.sequence;
    return a.data.beat_index - b.data.beat_index;
  });

---

<Layout title={`Episode ${episode.data.episode_number} – ${episode.data.title}`}>
  <div class="episode-header">
    <div class="episode-meta">
      <h1>
        Episode {episode.data.episode_number}: {episode.data.title}
      </h1>

      <div class="meta-info">
        <span class="scene-count">
          {resolvedScenes.length} Scenes
        </span>

        {episode.data.estimated_runtime && (
          <span class="runtime">
            ~{episode.data.estimated_runtime} min
          </span>
        )}
        {calculatedRuntime && (
          <span class="runtime">
            {calculatedRuntime} pages
          </span>
        )}
        <PrintToPdf />
      </div>
    </div>

    <div class="episode-details">
      {episode.data.logline && (
        <p class="logline">{episode.data.logline}</p>
      )}

      <div class="detail-section">
        <strong>Locations:</strong>
        <div class="tag-list">
          {sortedLocations.map((loc) => (
            <a href={`/locations/${(loc as any).slug}`} class="tag location-tag">
              {(loc as any).data.name}
            </a>
          ))}
        </div>
      </div>

      <div class="detail-section">
        <strong>Characters:</strong>
        <div class="tag-list">
          {sortedCharacters.map((char) => (
            <a href={`/characters/${(char as any).slug}`} class="tag character-tag">
              {(char as any).data.name}
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Beats Pressure Timeline Accordion -->
    {episodeBeats.length > 0 && (
      <div class="beats-accordion">
        <details class="accordion-item">
          <summary class="accordion-header">
            <h3>Story Beats & Pressure Timeline</h3>
            <span class="accordion-toggle">▼</span>
          </summary>
          <div class="accordion-content">
            <!-- Pressure Timeline Graph -->
            <div class="pressure-timeline">
              <h4>Pressure Level Timeline</h4>
              <div class="timeline-container">
                <svg class="pressure-graph" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                  <!-- Grid lines -->
                  <defs>
                    <pattern id="grid" width="80" height="20" patternUnits="userSpaceOnUse">
                      <path d="M 80 0 L 0 0 0 20" fill="none" stroke="#e5e7eb" stroke-width="0.5"/>
                    </pattern>
                  </defs>
                  <rect width="800" height="200" fill="url(#grid)" />
                  
                  <!-- Y-axis labels (Pressure levels 1-10) -->
                  {Array.from({length: 10}, (_, i) => (
                    <text x="10" y={20 + i * 18} class="axis-label" text-anchor="start">{10 - i}</text>
                  ))}
                  
                  <!-- Pressure line -->
                  <polyline
                    points={episodeBeats.map((beat, index) => {
                      const x = 50 + (index * (700 / Math.max(episodeBeats.length - 1, 1)));
                      const y = 180 - (beat.data.pressure_level * 18);
                      return `${x},${y}`;
                    }).join(' ')}
                    fill="none"
                    stroke="#3b82f6"
                    stroke-width="2"
                  />
                  
                  <!-- Data points -->
                  {episodeBeats.map((beat, index) => {
                    const x = 50 + (index * (700 / Math.max(episodeBeats.length - 1, 1)));
                    const y = 180 - (beat.data.pressure_level * 18);
                    return (
                      <circle cx={x} cy={y} r="4" fill="#3b82f6" class="data-point">
                        <title>{beat.data.title}: Pressure {beat.data.pressure_level}</title>
                      </circle>
                    );
                  })}
                  
                  <!-- X-axis labels (Beat numbers) -->
                  {episodeBeats.map((beat, index) => {
                    const x = 50 + (index * (700 / Math.max(episodeBeats.length - 1, 1)));
                    return (
                      <text x={x} y="195" class="beat-label" text-anchor="middle">{beat.data.beat_index}</text>
                    );
                  })}
                </svg>
              </div>
            </div>
            
            <!-- Beats List -->
            <div class="beats-list">
              <h4>Story Beats</h4>
              <div class="beats-grid">
                {episodeBeats.map((beat) => (
                  <div class="beat-card" data-pressure={beat.data.pressure_level}>
                    <div class="beat-header">
                      <span class="beat-title">{beat.data.title}</span>
                      <span class="beat-pressure">P{beat.data.pressure_level}</span>
                    </div>
                    <div class="beat-details">
                      <div class="beat-meta">
                        <span class="beat-type">{beat.data.beat_type}</span>
                        <span class="beat-act">Act {beat.data.act}</span>
                        <span class="beat-scene">Scene {beat.data.scene_number}</span>
                      </div>
                      <div class="beat-shift">
                        <strong>Shift:</strong> {beat.data.shift}
                      </div>
                      <div class="beat-character">
                        <strong>Primary:</strong> {beat.data.primary_character}
                      </div>
                      {beat.data.opposition && (
                        <div class="beat-opposition">
                          <strong>Opposition:</strong> {beat.data.opposition}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </details>
      </div>
    )}
    
    <!-- Voice Configuration -->
    <VoiceConfigurator 
      characters={sortedCharacters.map(char => ({ name: (char as any).data.name, slug: (char as any).slug }))}
      narrator={true}
    />
    
    <EpisodeNav currentSlug={(episode as any).slug} />
  </div>

  <div class="screenplay-container"> 
    <div class="screenplay-root">
      <div class="screenplay-page">
        {renderedScenes.map(({ scene, Content }) => (
          <div
            class="scene-break"
            id={`scene-${scene.data.scene_number}`}
          >
            <Content
              components={{
                Screenplay,
                Scene,
                Action,
                Character,
                Dialogue,
                Parenthetical,
                Transition,
                ActBreak,
              }}
            />
          </div>
        ))}
      </div>
      <EpisodeNav currentSlug={(episode as any).slug} />
    </div>
  </div>

  <PageBreaker />

  <!-- Global Speech Handler for Episodes -->
  <script type="module">
    import("/src/utils/speech/globalSpeechHandler.js");
  </script>

</Layout>

<style is:global>
  @media print {
    @page {
      size: Letter;
      margin: 0;
    }

    html,
    body {
      margin: 0 !important;
      padding: 0 !important;
      background: #fff !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    body > header,
    body > footer,
    header,
    nav,
    footer,
    .episode-header,
    .back-link,
    .tag-list,
    .episode-details {
      display: none !important;
    }

    main {
      margin: 0 !important;
      padding: 0 !important;
    }

    .screenplay-container {
      margin: 0 !important;
      padding: 0 !important;
    }

    .screenplay-root {
      border: none !important;
      width: 8.5in !important;
      margin: 0 auto !important;
    }

    .screenplay-root .screenplay-page {
      border: none !important;
      margin: 0 !important;
      padding-top: 1in !important;
      padding-bottom: 1in !important;
      min-height: auto !important;
      border-bottom: none !important;
      margin-bottom: 0 !important;
    }

    .screenplay-root .screenplay-page::after {
      display: none !important;
    }
  }
</style>

<style>
  .episode-header {
    max-width: 8.5in;
    margin: 0 auto 2rem;
    padding: 1.5rem;
    background: #f9f9f9;
    border-radius: 8px;
  }

  .episode-meta {
    margin-bottom: 1rem;
  }

  .episode-meta h1 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .meta-info {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .scene-count,
  .runtime {
    background: #eef2ff;
    color: #1e3a8a;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: bold;
  }

  .logline {
    font-style: italic;
    margin-bottom: 1rem;
  }

  .episode-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-section strong {
    display: block;
    margin-bottom: 0.5rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-decoration: none;
  }

  .location-tag {
    background: #fff3e0;
    color: #e65100;
    border: 1px solid #ffcc80;
  }

  .character-tag {
    background: #e3f2fd;
    color: #1565c0;
    border: 1px solid #90caf9;
  }

  .scene-break {
    margin-bottom: 2em;
  }

  .voice-configurator {
    margin: 1.5rem 0;
    padding: 1rem;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  /* Beats Accordion Styles */
  .beats-accordion {
    margin: 1.5rem 0;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .accordion-item {
    border: none;
  }

  .accordion-item[open] .accordion-toggle {
    transform: rotate(180deg);
  }

  .accordion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: #f8fafc;
    cursor: pointer;
    user-select: none;
    border: none;
    list-style: none;
  }

  .accordion-header::-webkit-details-marker {
    display: none;
  }

  .accordion-header h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: #1f2937;
  }

  .accordion-toggle {
    transition: transform 0.2s ease;
    color: #6b7280;
    font-size: 0.875rem;
  }

  .accordion-content {
    padding: 1.5rem;
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
  }

  /* Pressure Timeline Styles */
  .pressure-timeline {
    margin-bottom: 2rem;
  }

  .pressure-timeline h4 {
    margin: 0 0 1rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: #374151;
  }

  .timeline-container {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
  }

  .pressure-graph {
    width: 100%;
    height: 200px;
    max-width: 800px;
  }

  .axis-label {
    font-size: 10px;
    fill: #6b7280;
  }

  .beat-label {
    font-size: 10px;
    fill: #6b7280;
  }

  .data-point {
    cursor: pointer;
    transition: r 0.2s ease;
  }

  .data-point:hover {
    r: 6;
  }

  /* Beats List Styles */
  .beats-list h4 {
    margin: 0 0 1rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: #374151;
  }

  .beats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .beat-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1rem;
    transition: all 0.2s ease;
  }

  .beat-card:hover {
    border-color: #3b82f6;
    box-shadow: 0 2px 4px rgba(59, 130, 246, 0.1);
  }

  .beat-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .beat-title {
    font-weight: 600;
    color: #1f2937;
    font-size: 0.875rem;
    flex: 1;
    margin-right: 0.5rem;
  }

  .beat-pressure {
    background: #3b82f6;
    color: white;
    padding: 0.125rem 0.375rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    min-width: 24px;
    text-align: center;
  }

  .beat-details {
    font-size: 0.813rem;
    color: #4b5563;
  }

  .beat-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .beat-type,
  .beat-act,
  .beat-scene {
    background: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: capitalize;
  }

  .beat-type {
    background: #fef3c7;
    color: #92400e;
  }

  .beat-act {
    background: #dbeafe;
    color: #1e40af;
  }

  .beat-scene {
    background: #e0e7ff;
    color: #3730a3;
  }

  .beat-shift,
  .beat-character,
  .beat-opposition {
    margin-bottom: 0.375rem;
  }

  .beat-shift strong,
  .beat-character strong,
  .beat-opposition strong {
    color: #1f2937;
  }

  /* Pressure level color coding */
  .beat-card[data-pressure="1"],
  .beat-card[data-pressure="2"],
  .beat-card[data-pressure="3"] {
    border-left: 4px solid #10b981;
  }

  .beat-card[data-pressure="4"],
  .beat-card[data-pressure="5"],
  .beat-card[data-pressure="6"] {
    border-left: 4px solid #f59e0b;
  }

  .beat-card[data-pressure="7"],
  .beat-card[data-pressure="8"],
  .beat-card[data-pressure="9"],
  .beat-card[data-pressure="10"] {
    border-left: 4px solid #ef4444;
  }

  @media print {
    .episode-header {
      page-break-after: always;
    }
    
    .voice-configurator {
      display: none !important;
    }
  }
</style>
